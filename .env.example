# Rappi Claude Plugin — Environment Variables
# Copy this to .env and fill in your values (or set in Railway dashboard)

# Required for remote deployment (Railway/Cowork)
RAPPI_TOKEN=ft.your-token-here          # From ~/.rappi/config.json after `rappi auth login`
RAPPI_DEVICE_ID=your-device-id-here     # From ~/.rappi/config.json
MCP_TRANSPORT=sse                        # "sse" for Railway, "stdio" for local (default)

# Optional
RAPPI_COUNTRY=co                         # "co" (Colombia) or "mx" (Mexico)

# Optional — OpenAI embeddings for semantic search
# OPENAI_API_KEY=sk-your-key-here

# Not needed — coordinates are auto-synced from your Rappi active address
# RAPPI_LAT=4.689
# RAPPI_LNG=-74.038
